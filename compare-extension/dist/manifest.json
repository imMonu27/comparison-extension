{
  "manifest_version": 3,
  "name": "Compare Extension",
  "version": "1.0.0",
  "description": "Universal Comparison Extension",
  "action": {
    "default_popup": "index.html"
  },
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "https://property.com.au/*",
    "https://www.property.com.au/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://property.com.au/*",
        "https://www.property.com.au/*"
      ],
      "js": [
        "src/content.ts-loader.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "service-worker-loader.js",
    "type": "module"
  },
  "web_accessible_resources": [
    {
      "matches": [
        "<all_urls>"
      ],
      "resources": [
        "**/*",
        "*"
      ],
      "use_dynamic_url": false
    }
  ]
}
